<style>
    footer {
        padding: 3em 1em;
        background: #ffffff;
        color: #586069;
        text-align: center;
        border-top: 1px solid #e1e4e8;
    }

    .footer-content {
        max-width: 1100px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1em;
    }

    p {
        margin: 0;
    }

    .social-links {
        display: flex;
        justify-content: center;
        gap: 1.5em;
    }

    .social-links a {
        text-decoration: none;
        color: #586069;
        transition: color 0.2s ease;
    }

    .social-links a:hover {
        color: #0e75b6;
    }
</style>