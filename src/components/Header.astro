---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
    <nav>
        <h2><a href="/">{SITE_TITLE}</a></h2>
        <div class="internal-links">
            <HeaderLink href="/">Inicio</HeaderLink>
            <HeaderLink href="/projects">Proyectos</HeaderLink>
            <HeaderLink href="/stack">Stack</HeaderLink>
            <HeaderLink href="/profile">Perfil</HeaderLink>
        </div>
        <div class="social-links">
            <a href="https://github.com/alvarofdezr" target="_blank">
                <span class="sr-only">Go to GitHub repo</span>
                <svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
                    ><path
                        fill="currentColor"
                        d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
                    ></path></svg
                >
            </a>
            
            <a href="https://www.linkedin.com/in/%C3%A1lvaro-fern%C3%A1ndez-71b25a404" target="_blank">
                <span class="sr-only">Go to LinkedIn profile</span>
                <svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
                    ><path 
                        fill="currentColor"
                        d="M14.82 0H1.18A1.17 1.17 0 000 1.15v13.7A1.17 1.17 0 001.18 16h13.64A1.18 1.18 0 0016 14.85V1.15A1.18 1.18 0 0014.82 0zM4.74 13.68H2.3V5.9h2.45v7.78zM3.52 4.84h-.02a1.22 1.22 0 01-1.23-1.22c0-.68.56-1.23 1.25-1.23s1.23.54 1.24 1.23a1.22 1.22 0 01-1.24 1.22zm10.16 8.84h-2.44V9.82c0-1-.36-1.68-1.26-1.68-.69 0-1.1.46-1.28.91-.07.16-.08.38-.08.61v4.02H6.18s.03-7.05 0-7.78h2.44v1.1c.32-.5 1-1.22 2.24-1.22 1.63 0 2.86 1.07 2.86 3.37v4.51z"
                    ></path></svg>
            </a>
        </div>
    </nav>
</header>

<style>
    header {
        margin: 0;
        padding: 0;
        background: white;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        position: sticky;
        top: 0;
        z-index: 100;
    }
    
    h2 {
        margin: 0;
        font-size: 1.1em;
        font-weight: 700;
        white-space: nowrap;
    }

    h2 a, h2 a.active {
        text-decoration: none;
        color: #111827;
    }
    
    nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 1100px;
        margin: 0 auto;
        padding: 0.8em 1.5em;
        gap: 1em;
    }
    
    .internal-links {
        display: flex;
        align-items: center;
        gap: 1.5em;
    }
    
    nav a {
        padding: 0.5em 0;
        color: #4b5563;
        border-bottom: 2px solid transparent;
        text-decoration: none;
        font-size: 0.95em;
        font-weight: 500;
        transition: color 0.2s, border-color 0.2s;
    }
    
    nav a:hover,
    nav a.active {
        color: #0e75b6;
        border-bottom-color: #0e75b6;
    }
    
    .social-links {
        display: flex;
        align-items: center;
        gap: 0.5em;
        color: #4b5563;
    }

    .social-links a:hover {
        color: #0e75b6;
    }
    
    @media (max-width: 768px) {
        nav {
            padding: 1em;
            flex-direction: column;
            gap: 1em;
        }
        
        .internal-links {
            justify-content: center;
            flex-wrap: wrap; 
            gap: 0.5em 1.5em;
        }
        
        .social-links {
            display: none;
        }
    }
</style>