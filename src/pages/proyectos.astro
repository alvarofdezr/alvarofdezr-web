---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Proyectos | Álvaro Fernández";
const description = "Portfolio de proyectos destacados en ciberseguridad, EDR y desarrollo de software seguro.";
---

<!DOCTYPE html>
<html lang="es">
<head>
    <BaseHead title={title} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; }

        :root {
            --primary:      #0e75b6;
            --primary-light:#e8f4fc;
            --bg:           #fafbfc;
            --surface:      #ffffff;
            --border:       #e1e4e8;
            --border-med:   #d0d7de;
            --text:         #24292e;
            --text-2:       #586069;
            --text-3:       #959da5;
            --green:        #1a7f37;
            --green-bg:     #dafbe1;
            --amber:        #9a6700;
            --amber-bg:     #fff8c5;
            --mono:         'IBM Plex Mono', monospace;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        .wrapper {
            width: auto;
            box-sizing: border-box; 
            max-width: 1100px;
            margin: 0 auto;
            padding: 4rem 2rem 6rem;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            color: var(--text-2);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            margin-bottom: 2.5rem;
            transition: color 0.2s;
        }
        .back-link:hover { color: var(--primary); }

        .page-header {
            margin-bottom: 4rem;
            max-width: 680px;
        }

        .eyebrow {
            font-family: var(--mono);
            font-size: 0.75rem;
            color: var(--primary);
            letter-spacing: 0.12em;
            text-transform: uppercase;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        .eyebrow::after {
            content: '';
            display: inline-block;
            width: 40px;
            height: 1px;
            background: var(--border);
        }

        .page-header h1 {
            font-size: clamp(2.2rem, 5vw, 3.4rem);
            font-weight: 800;
            color: #111827;
            letter-spacing: -0.035em;
            line-height: 1.1;
            margin: 0 0 1.25rem;
        }

        .page-header p {
            font-size: 1.05rem;
            color: var(--text-2);
            margin: 0 0 2rem;
            line-height: 1.65;
        }

        .stats-bar {
            display: flex;
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            width: fit-content;
            background: var(--surface);
        }
        .stat-item {
            padding: 0.8rem 1.6rem;
            border-right: 1px solid var(--border);
        }
        .stat-item:last-child { border-right: none; }
        .stat-num {
            display: block;
            font-size: 1.4rem;
            font-weight: 800;
            color: var(--text);
            letter-spacing: -0.03em;
            line-height: 1;
            margin-bottom: 0.2rem;
        }
        .stat-label {
            display: block;
            font-family: var(--mono);
            font-size: 0.68rem;
            color: var(--text-3);
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        /* ── SECURECHAIN ── */
        .project-featured {
            border: 1px solid var(--border);
            border-radius: 12px;
            background: var(--surface);
            padding: 2.5rem;
            margin-bottom: 1.5rem;
            position: relative;
            transition: border-color 0.25s, box-shadow 0.25s;
        }
        .project-featured::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: var(--primary);
            border-radius: 12px 12px 0 0;
        }
        .project-featured:hover {
            border-color: var(--primary);
            box-shadow: 0 4px 24px rgba(14,117,182,0.08);
        }

        .featured-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.25rem;
            flex-wrap: wrap;
            gap: 1rem;
        }
        .featured-title-row {
            display: flex;
            align-items: center;
            gap: 0.9rem;
        }
        .project-icon { font-size: 1.7rem; line-height: 1; }

        .project-title {
            font-size: 1.85rem;
            font-weight: 700;
            color: #111827;
            letter-spacing: -0.025em;
            margin: 0;
            line-height: 1.2;
        }

        .featured-desc {
            font-size: 0.97rem;
            color: var(--text-2);
            line-height: 1.7;
            margin: 0 0 1.5rem;
            max-width: 780px;
        }

        /* ecosistemas en fila horizontal */
        .ecosystems {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
            margin-bottom: 1.5rem;
        }
        .eco-pill {
            font-family: var(--mono);
            font-size: 0.7rem;
            color: var(--primary);
            background: var(--primary-light);
            border: 1px solid rgba(14,117,182,0.2);
            padding: 0.22rem 0.65rem;
            border-radius: 4px;
            letter-spacing: 0.04em;
        }

        .features {
            list-style: none;
            padding: 0;
            margin: 0 0 1.75rem;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 0.5rem 2rem;
        }
        .features.one-col { grid-template-columns: 1fr; }
        .features li {
            font-size: 0.875rem;
            color: var(--text-2);
            display: flex;
            gap: 0.5rem;
            align-items: flex-start;
            line-height: 1.5;
        }
        .features li::before {
            content: '→';
            color: var(--primary);
            font-size: 0.75rem;
            margin-top: 0.2rem;
            flex-shrink: 0;
        }

        .card-footer {
            padding-top: 1.25rem;
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }
        .tech-stack { display: flex; flex-wrap: wrap; gap: 0.35rem; }
        .tech-pill {
            font-family: var(--mono);
            font-size: 0.68rem;
            color: var(--text-3);
            background: var(--bg);
            border: 1px solid var(--border);
            padding: 0.18rem 0.55rem;
            border-radius: 4px;
            letter-spacing: 0.04em;
            transition: color 0.2s, border-color 0.2s;
        }
        .project-featured:hover .tech-pill,
        .project-card:hover .tech-pill {
            color: var(--text-2);
            border-color: var(--border-med);
        }

        .btn-group { display: flex; gap: 0.5rem; }
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            font-size: 0.82rem;
            font-weight: 600;
            padding: 0.45rem 1rem;
            border-radius: 6px;
            text-decoration: none;
            border: 1px solid;
            transition: all 0.2s;
            white-space: nowrap;
        }
        .btn-primary { background: var(--primary); color: #fff; border-color: var(--primary); }
        .btn-primary:hover { background: #0b5b8e; border-color: #0b5b8e; }
        .btn-ghost { background: transparent; color: var(--text-2); border-color: var(--border); }
        .btn-ghost:hover { border-color: var(--primary); color: var(--primary); }

        .badge {
            font-family: var(--mono);
            font-size: 0.66rem;
            font-weight: 500;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            padding: 0.22rem 0.65rem;
            border-radius: 20px;
        }
        .badge-blue  { background: var(--primary-light); color: var(--primary); }
        .badge-green { background: var(--green-bg); color: var(--green); }
        .badge-amber { background: var(--amber-bg); color: var(--amber); }

        /* ── GRIDS ── */
        .projects-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem;
            margin-bottom: 1.5rem;
        }
        .projects-bottom {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
        }

        .project-card {
            border: 1px solid var(--border);
            border-radius: 12px;
            background: var(--surface);
            padding: 2rem;
            display: flex;
            flex-direction: column;
            transition: border-color 0.25s, box-shadow 0.25s;
        }
        .project-card:hover {
            border-color: var(--border-med);
            box-shadow: 0 4px 16px rgba(0,0,0,0.06);
        }
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1.1rem;
        }
        .card-meta { display: flex; align-items: center; gap: 0.7rem; }
        .project-num {
            font-family: var(--mono);
            font-size: 0.68rem;
            color: var(--text-3);
            letter-spacing: 0.06em;
        }
        .card-title {
            font-size: 1.3rem;
            font-weight: 700;
            color: #111827;
            letter-spacing: -0.02em;
            margin: 0 0 0.6rem;
            line-height: 1.2;
        }
        .card-desc {
            font-size: 0.9rem;
            color: var(--text-2);
            line-height: 1.65;
            margin: 0 0 1.1rem;
            flex-grow: 1;
        }

        .view-more {
            margin-top: 3rem;
            padding-top: 2.5rem;
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }
        .view-more p { color: var(--text-2); font-size: 0.95rem; margin: 0; }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(14px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .page-header     { animation: fadeUp 0.5s ease both; }
        .project-featured{ animation: fadeUp 0.5s 0.1s ease both; }
        .projects-grid   { animation: fadeUp 0.5s 0.18s ease both; }
        .projects-bottom { animation: fadeUp 0.5s 0.24s ease both; }

        @media (max-width: 900px) {
            .projects-grid { grid-template-columns: 1fr; }
            .projects-bottom { grid-template-columns: 1fr; }
        }
        @media (max-width: 600px) {
            .wrapper { padding: 2.5rem 1.5rem 4rem; }
            .project-featured { padding: 1.75rem; }
            .project-card { padding: 1.5rem; }
            .stats-bar { width: 100%; }
            .stat-item { flex: 1; padding: 0.7rem 1rem; }
            .card-footer { flex-direction: column; align-items: flex-start; }
            .view-more { flex-direction: column; }
        }
    </style>
</head>
<body>
    <Header />

    <main class="wrapper">

        <a href="/" class="back-link">← Volver al inicio</a>

        <div class="page-header">
            <p class="eyebrow">Investigación & Desarrollo</p>
            <h1>Herramientas que construí<br>para entender.</h1>
            <p>
                Seguridad ofensiva, arquitecturas defensivas y proyectos académicos.
                Cada línea escrita para aprender más de lo que enseña.
            </p>
            <div class="stats-bar">
                <div class="stat-item">
                    <span class="stat-num">6</span>
                    <span class="stat-label">Proyectos</span>
                </div>
                <div class="stat-item">
                    <span class="stat-num">4</span>
                    <span class="stat-label">Lenguajes</span>
                </div>
                <div class="stat-item">
                    <span class="stat-num">2</span>
                    <span class="stat-label">EDRs</span>
                </div>
                <div class="stat-item">
                    <span class="stat-num">1</span>
                    <span class="stat-label">TFG</span>
                </div>
            </div>
        </div>

        <!-- 01 · SECURECHAIN -->
        <div class="project-featured">
            <div class="featured-top">
                <div class="featured-title-row">
                    <span class="project-icon">⛓️</span>
                    <h2 class="project-title">SecureChain</h2>
                    <span class="badge badge-blue">TFG</span>
                </div>
                <div class="btn-group">
                    <a href="https://github.com/alvarofdezr/securechain-ssc-ingestion" target="_blank" class="btn btn-primary">↗ Ingestion</a>
                    <a href="https://github.com/alvarofdezr/securechain-depex" target="_blank" class="btn btn-ghost">↗ DepEx</a>
                </div>
            </div>

            <p class="featured-desc">
                Mi Trabajo de Fin de Grado. Consiste en la ampliación para el ecosistema del lenguaje Go
                de las herramientas de la plataforma de análisis SecureChain (Ingestion y DepEx). Permite la ingesta masiva
                de metadatos y la resolución de complejos árboles de dependencias en proyectos Go.
            </p>

            <div class="ecosystems">
                <span class="eco-pill">Go modules</span>
                <span class="eco-pill">Cargo</span>
                <span class="eco-pill">npm</span>
                <span class="eco-pill">PyPI</span>
                <span class="eco-pill">Maven</span>
            </div>

            <ul class="features">
                <li>Integración nativa de módulos Go en la arquitectura de microservicios (FastAPI, Redis, Dagster)</li>
                <li>Resolución formal de restricciones de versiones de Go mediante Z3 Theorem Prover (SMT)</li>
                <li>Ampliación del motor DepEx para la exploración exhaustiva de dependencias transitivas</li>
                <li>Generación de SBOMs en formato CycloneDX y SPDX a partir de manifiestos go.mod</li>
            </ul>

            <div class="card-footer">
                <div class="tech-stack">
                    <span class="tech-pill">Python</span>
                    <span class="tech-pill">Go</span>
                    <span class="tech-pill">FastAPI</span>
                    <span class="tech-pill">Dagster</span>
                    <span class="tech-pill">Redis</span>
                    <span class="tech-pill">Z3</span>
                    <span class="tech-pill">Docker</span>
                    <span class="tech-pill">CycloneDX</span>
                </div>
            </div>
        </div>

        <!-- 02 + 03 -->
        <div class="projects-grid">

            <div class="project-card">
                <div class="card-header">
                    <div class="card-meta">
                        <span class="project-icon">🛡️</span>
                        <span class="project-num">02</span>
                    </div>
                    <span class="badge badge-amber">Active</span>
                </div>
                <h2 class="card-title">Aegis Sentinel</h2>
                <p class="card-desc">
                    Plataforma EDR de próxima generación. Evoluciona la arquitectura base de Basilisk
                    para ofrecer capacidades avanzadas de monitorización y respuesta automatizada.
                </p>
                <ul class="features one-col">
                    <li>Monitorización mejorada: procesos, red, FIM y USB</li>
                    <li>Escaneo YARA + inteligencia de VirusTotal integrada</li>
                    <li>C2 HTTPS con control de acceso por roles (RBAC)</li>
                </ul>
                <div class="card-footer">
                    <div class="tech-stack">
                        <span class="tech-pill">Python</span>
                        <span class="tech-pill">EDR</span>
                        <span class="tech-pill">Docker</span>
                        <span class="tech-pill">RBAC</span>
                    </div>
                    <a href="https://github.com/alvarofdezr/Aegis-sentinel" target="_blank" class="btn btn-ghost">↗ Repo</a>
                </div>
            </div>

            <div class="project-card">
                <div class="card-header">
                    <div class="card-meta">
                        <span class="project-icon">🔐</span>
                        <span class="project-num">03</span>
                    </div>
                    <span class="badge badge-green">v2.0.0</span>
                </div>
                <h2 class="card-title">Harpocrates</h2>
                <p class="card-desc">
                    Gestor de contraseñas CLI/GUI con arquitectura local Zero-Trust. Seguridad
                    de grado militar para almacenamiento de credenciales sin depender de la nube.
                </p>
                <ul class="features one-col">
                    <li>Bóveda de doble factor: Master Password + 128-bit Secret Key</li>
                    <li>Cifrado AES-256-GCM con derivación Argon2id</li>
                    <li>Log de auditoría antimanipulación</li>
                </ul>
                <div class="card-footer">
                    <div class="tech-stack">
                        <span class="tech-pill">Python</span>
                        <span class="tech-pill">Cryptography</span>
                        <span class="tech-pill">CI/CD</span>
                    </div>
                    <a href="https://github.com/alvarofdezr/Harpocrates" target="_blank" class="btn btn-ghost">↗ Repo</a>
                </div>
            </div>

        </div>

        <!-- 04 + 05 + 06 -->
        <div class="projects-bottom">

            <div class="project-card">
                <div class="card-header">
                    <div class="card-meta">
                        <span class="project-icon">🐍</span>
                        <span class="project-num">04</span>
                    </div>
                    <span class="badge badge-green">Completed</span>
                </div>
                <h2 class="card-title">Basilisk</h2>
                <p class="card-desc">
                    Sistema EDR modular base con agente de bajo nivel, servidor C2 y dashboard
                    web en tiempo real. Base arquitectónica de Aegis Sentinel.
                </p>
                <ul class="features one-col">
                    <li>Monitorización de red, procesos, FIM y registro</li>
                    <li>Integración de escaneo con reglas YARA</li>
                </ul>
                <div class="card-footer">
                    <div class="tech-stack">
                        <span class="tech-pill">Python</span>
                        <span class="tech-pill">FastAPI</span>
                        <span class="tech-pill">YARA</span>
                    </div>
                    <a href="https://github.com/alvarofdezr/Basilisk" target="_blank" class="btn btn-ghost">↗ Repo</a>
                </div>
            </div>

            <div class="project-card">
                <div class="card-header">
                    <div class="card-meta">
                        <span class="project-icon">⚔️</span>
                        <span class="project-num">05</span>
                    </div>
                    <span class="badge badge-amber">Ofensivo</span>
                </div>
                <h2 class="card-title">Ares</h2>
                <p class="card-desc">
                    Toolkit de seguridad ofensiva de alto rendimiento para reconocimiento de
                    redes, descubrimiento de vulnerabilidades y automatización de payloads.
                </p>
                <ul class="features one-col">
                    <li>Motor de escaneo de puertos altamente concurrente</li>
                    <li>Arquitectura modular para nuevos exploits</li>
                </ul>
                <div class="card-footer">
                    <div class="tech-stack">
                        <span class="tech-pill">Go</span>
                        <span class="tech-pill">Networking</span>
                        <span class="tech-pill">Concurrency</span>
                    </div>
                    <a href="https://github.com/alvarofdezr/Ares" target="_blank" class="btn btn-ghost">↗ Repo</a>
                </div>
            </div>

            <div class="project-card">
                <div class="card-header">
                    <div class="card-meta">
                        <span class="project-icon">💬</span>
                        <span class="project-num">06</span>
                    </div>
                    <span class="badge badge-green">Completed</span>
                </div>
                <h2 class="card-title">Cript</h2>
                <p class="card-desc">
                    Framework didáctico de simulación de protocolos criptográficos seguros.
                    Canales E2EE con Double Ratchet y derivación HKDF.
                </p>
                <ul class="features one-col">
                    <li>Comunicación segura End-to-End (E2EE)</li>
                    <li>Derivación HKDF + mecanismo Double Ratchet</li>
                </ul>
                <div class="card-footer">
                    <div class="tech-stack">
                        <span class="tech-pill">Python</span>
                        <span class="tech-pill">E2EE</span>
                        <span class="tech-pill">Cryptography</span>
                    </div>
                    <a href="https://github.com/alvarofdezr/cript" target="_blank" class="btn btn-ghost">↗ Repo</a>
                </div>
            </div>

        </div>

        <div class="view-more">
            <p>¿Buscas configuraciones, scripts menores o mi actividad diaria?</p>
            <a href="https://github.com/alvarofdezr" target="_blank" class="btn btn-ghost">
                Ver todos los repositorios en GitHub →
            </a>
        </div>

    </main>

    <Footer />
</body>
</html>