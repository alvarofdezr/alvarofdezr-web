---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Stack & Certificaciones | Álvaro Fernández Ramos";
const description = "Arsenal tecnológico, entornos de desarrollo, aplicaciones y progreso en certificaciones de ciberseguridad.";
---

<!DOCTYPE html>
<html lang="es">
<head>
    <BaseHead title={title} description={description} />
    <style>
        /* =========================================
           VARIABLES GLOBALES Y RESET
           ========================================= */
        :root {
            --primary: #0e75b6;
            --bg-color: #fafbfc;
            --text-main: #24292e;
            --text-muted: #586069;
            --card-bg: #ffffff;
            --border-color: #e1e4e8;
        }

        *, *::before, *::after { box-sizing: border-box; }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        .layout-wrapper {
            width: auto;
            max-width: 1100px;
            margin: 0 auto;
            padding: 4rem 2rem;
            min-height: calc(100vh - 160px);
        }

        .page-header {
            margin-bottom: 4rem;
        }

        .page-header h1 {
            font-size: clamp(2.2rem, 5vw, 3.5rem);
            margin: 0 0 1rem 0;
            color: #111827;
            font-weight: 800;
            letter-spacing: -0.04em;
            line-height: 1.1;
        }

        .page-header p {
            font-size: 1.15rem;
            color: var(--text-muted);
            max-width: 750px;
        }

        /* =========================================
           SECCIONES Y GRIDS
           ========================================= */
        .section-title {
            font-size: 1.8rem;
            color: #111827;
            margin-bottom: 2rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid var(--border-color);
            display: inline-block;
        }

        section {
            margin-bottom: 5rem;
        }

        .grid-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
        }

        /* =========================================
           TARJETAS DE CONTENIDO
           ========================================= */
        .card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 2rem;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border-top: 4px solid var(--primary);
            display: flex;
            flex-direction: column;
        }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 20px -8px rgba(0, 0, 0, 0.1);
        }

        .card h3 {
            margin: 0 0 1rem 0;
            font-size: 1.3rem;
            color: #111827;
        }

        .card p {
            margin: 0;
            color: var(--text-muted);
            font-size: 0.95rem;
            line-height: 1.6;
            flex-grow: 1;
        }

        .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-top: 1.5rem;
        }

        .tag {
            background: #f1f8ff;
            color: var(--primary);
            padding: 0.3rem 0.8rem;
            border-radius: 999px;
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 0.03em;
        }

        /* =========================================
           BADGES DE CERTIFICACIONES
           ========================================= */
        .cert-status {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            border-radius: 6px;
            font-size: 0.8rem;
            font-weight: 600;
            margin-bottom: 1rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            width: fit-content;
        }

        .status-roadmap { background: #f3f4f6; color: #4b5563; }
        .status-progress { background: #fff8c5; color: #9a6700; }
        .status-achieved { background: #dcffe4; color: #1a7f37; }

        @media (max-width: 600px) {
            .layout-wrapper { padding: 2rem 1.5rem; }
            .card { padding: 1.5rem; }
        }
        @media (prefers-reduced-motion: reduce) {
            * {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
                scroll-behavior: auto !important;
                opacity: 1 !important;
            }
        }
        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            color: var(--text-2);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            margin-bottom: 2.5rem;
            transition: color 0.2s;
        }
        .back-link:hover { color: var(--primary); }

    </style>
</head>
<body>
    <Header />
    
    <main class="layout-wrapper">

        <a href="/" class="back-link">← Volver al inicio</a>

        <header class="page-header">
            <h1>Stack & herramientas</h1>
            <p>Un vistazo a las tecnologías, bases de datos y aplicaciones que utilizo en mi día a día para construir soluciones seguras, analizar tráfico y desplegar entornos de auditoría.</p>
        </header>

        <section>
            <h2 class="section-title">Lenguajes y ecosistema</h2>
            <div class="grid-container">
                <div class="card">
                    <h3>Desarrollo core</h3>
                    <p>Lenguajes principales utilizados en la creación de agentes EDR, herramientas de seguridad y sistemas de alto rendimiento.</p>
                    <div class="tags">
                        <span class="tag">Python</span>
                        <span class="tag">Go</span>
                    </div>
                </div>

                <div class="card">
                    <h3>Frameworks & testing</h3>
                    <p>Construcción de APIs eficientes y pipelines de validación robustos para mantener un código seguro.</p>
                    <div class="tags">
                        <span class="tag">FastAPI</span>
                        <span class="tag">uv</span>
                        <span class="tag">Pytest</span>
                    </div>
                </div>

                <div class="card">
                    <h3>Gestión de paquetes</h3>
                    <p>Integración y análisis de dependencias abarcando múltiples ecosistemas de software.</p>
                    <div class="tags">
                        <span class="tag">Cargo</span>
                        <span class="tag">NPM</span>
                        <span class="tag">NuGet</span>
                    </div>
                </div>
            </div>
        </section>

        <section>
            <h2 class="section-title">Infraestructura y herramientas</h2>
            <div class="grid-container">
                <div class="card">
                    <h3>Virtualización y despliegue</h3>
                    <p>Gestión de contenedores y máquinas virtuales para aislar entornos de pruebas, auditorías y desarrollo.</p>
                    <div class="tags">
                        <span class="tag">Docker</span>
                        <span class="tag">VirtualBox</span>
                    </div>
                </div>

                <div class="card">
                    <h3>Bases de datos</h3>
                    <p>Almacenamiento relacional, documental y basado en grafos para gestionar grandes volúmenes de eventos y relaciones.</p>
                    <div class="tags">
                        <span class="tag">Neo4j</span>
                        <span class="tag">MongoDB</span>
                        <span class="tag">MariaDB</span>
                    </div>
                </div>

                <div class="card">
                    <h3>Análisis de red y seguridad</h3>
                    <p>Auditoría de sistemas, descubrimiento de vulnerabilidades, monitorización de intrusos y análisis de paquetes.</p>
                    <div class="tags">
                        <span class="tag">Wireshark</span>
                        <span class="tag">Nmap</span>
                        <span class="tag">Lynis</span>
                        <span class="tag">Suricata</span>
                    </div>
                </div>

                <div class="card">
                    <h3>Entornos e investigación</h3>
                    <p>Entornos de desarrollo integrados (IDE) y herramientas avanzadas de validación lógica y auditoría de código estático.</p>
                    <div class="tags">
                        <span class="tag">Eclipse</span>
                        <span class="tag">Z3 Theorem Prover</span>
                        <span class="tag">Bandit</span>
                    </div>
                </div>
            </div>
        </section>

        <section>
            <h2 class="section-title">Roadmap de certificaciones</h2>
            <div class="grid-container">
                <div class="card">
                    <span class="cert-status status-progress">Objetivo</span>
                    <h3>eJPT</h3>
                    <p>Junior Penetration Tester. Consolidando fundamentos prácticos de seguridad ofensiva, enumeración y auditoría de redes.</p>
                </div>

                <div class="card">
                    <span class="cert-status status-roadmap">Objetivo</span>
                    <h3>OSCP</h3>
                    <p>Offensive Security Certified Professional. Preparación continua orientada a obtener el estándar de la industria en pentesting.</p>
                </div>
                
                <div class="card">
                    <span class="cert-status status-achieved">Completado</span>
                    <h3>Cambridge B2 English</h3>
                    <p>Competencia profesional acreditada, fundamental para la lectura de documentación técnica, papers y redacción de reportes de vulnerabilidades.</p>
                </div>
            </div>
        </section>
    </main>
    
    <Footer />
</body>
</html>