---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Sobre Mí | Álvaro Fernández Ramos";
const description = "Trayectoria académica, filosofía de seguridad y objetivos profesionales de Álvaro Fernández Ramos.";
---

<!DOCTYPE html>
<html lang="es">
<head>
    <BaseHead title={title} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        /* Page-specific styles — common styles in global.css */
        *, *::before, *::after { box-sizing: border-box; }

        /* ── Partículas ── */

        .layout-wrapper {
            max-width: 900px;
            margin: 0 auto;
            padding: 4rem 2rem 7rem;
            position: relative;
            z-index: 1;
        }

        /* ── Back link ── */

        /* ── Page header ── */
        .page-header {
            margin-bottom: 4rem;
            opacity: 0;
            animation: fadeUp 0.6s ease 0.2s forwards;
        }

        .page-header h1 {
            font-family: var(--serif);
            font-size: clamp(2.6rem, 6vw, 4rem);
            margin: 0 0 0.75rem;
            color: var(--text);
            font-weight: 400;
            letter-spacing: -0.025em;
            line-height: 1.05;
        }

        .page-header h1 em {
            font-style: italic;
            color: var(--primary);
        }

        .page-header .lead {
            font-size: 1.05rem;
            color: var(--text-2);
            margin: 0;
            max-width: 540px;
            border-left: 2px solid var(--primary-border);
            padding-left: 1.2rem;
            line-height: 1.75;
        }

        /* ── Sections ── */
        .section {
            margin-bottom: 3rem;
            opacity: 0;
            animation: fadeUp 0.6s ease forwards;
        }
        .section:nth-child(1) { animation-delay: 0.3s; }
        .section:nth-child(2) { animation-delay: 0.4s; }
        .section:nth-child(3) { animation-delay: 0.5s; }

        /* ── Filosofía card ── */
        .philosophy-card {
            background: linear-gradient(135deg, #ffffff 0%, #eef5f8 100%);
            border: 1px solid #d4e4ec;
            border-left: 4px solid var(--primary);
            border-radius: 0 14px 14px 0;
            padding: 2.5rem;
            position: relative;
            overflow: hidden;
        }
        .philosophy-card::before {
            content: '"';
            position: absolute;
            right: 1.5rem;
            top: -1rem;
            font-family: var(--serif);
            font-size: 10rem;
            color: rgba(30,106,138,0.06);
            line-height: 1;
            pointer-events: none;
            user-select: none;
        }
        .philosophy-card p {
            font-size: 1.05rem;
            color: var(--text-2);
            line-height: 1.8;
            margin: 0 0 1.25rem;
        }
        .philosophy-card p:last-child { margin-bottom: 0; }
        .philosophy-card strong { color: var(--text); font-weight: 600; }
        .philosophy-card em {
            color: var(--primary);
            font-style: italic;
            font-family: var(--serif);
            font-size: 1.15rem;
        }

        /* ── Skills grid ── */
        .skills-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
        }

        .skill-card {
            background: linear-gradient(135deg, #ffffff 0%, #eef5f8 100%);
            border: 1px solid #d4e4ec;
            border-left: 4px solid var(--primary);
            border-radius: 0 10px 10px 0;
            padding: 1.25rem 1.5rem;
            transition: box-shadow 0.25s, border-color 0.25s;
        }
        .skill-card:hover {
            box-shadow: 0 4px 20px rgba(30,106,138,0.09);
            border-color: var(--primary-border);
        }
        .skill-title {
            font-family: var(--mono);
            font-size: 10px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--primary);
            margin-bottom: 0.6rem;
        }
        .skill-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 0.3rem;
        }
        .skill-tag {
            font-family: var(--mono);
            font-size: 0.68rem;
            color: var(--text-2);
            background: var(--bg);
            border: 1px solid var(--border);
            padding: 0.15rem 0.5rem;
            border-radius: 3px;
        }

        /* ── Timeline ── */
        .timeline {
            position: relative;
            padding-left: 2rem;
        }
        .timeline::before {
            content: '';
            position: absolute;
            left: 0;
            top: 6px;
            bottom: 6px;
            width: 2px;
            background: linear-gradient(to bottom, var(--primary), var(--primary-border));
            border-radius: 2px;
        }

        .timeline-item {
            position: relative;
            margin-bottom: 2.75rem;
            opacity: 0;
            transform: translateX(-12px);
            transition: opacity 0.5s ease, transform 0.5s ease;
        }
        .timeline-item.visible {
            opacity: 1;
            transform: translateX(0);
        }
        .timeline-item:last-child { margin-bottom: 0; }

        .timeline-item::before {
            content: '';
            position: absolute;
            left: -2.45rem;
            top: 0.4rem;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: var(--primary);
            border: 3px solid var(--bg);
            box-shadow: 0 0 0 2px var(--primary-border);
            transition: transform 0.3s ease;
        }
        .timeline-item:hover::before {
            transform: scale(1.3);
        }

        .time-date {
            display: inline-block;
            font-family: var(--mono);
            font-size: 0.72rem;
            color: var(--primary);
            background: var(--primary-light);
            border: 1px solid rgba(30,106,138,0.15);
            padding: 0.2rem 0.65rem;
            border-radius: 4px;
            margin-bottom: 0.65rem;
            letter-spacing: 0.03em;
        }

        .timeline-item h3 {
            font-family: var(--serif);
            font-size: 1.4rem;
            font-weight: 400;
            color: var(--text);
            margin: 0 0 0.5rem;
            line-height: 1.2;
            letter-spacing: -0.01em;
        }

        .timeline-item p {
            margin: 0;
            font-size: 0.95rem;
            color: var(--text-2);
            line-height: 1.7;
        }

        /* ── Idiomas ── */
        .lang-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 1rem;
        }
        .lang-card {
            background: linear-gradient(135deg, #ffffff 0%, #eef5f8 100%);
            border: 1px solid #d4e4ec;
            border-left: 4px solid var(--primary);
            border-radius: 0 10px 10px 0;
            padding: 1.25rem 1.5rem;
        }
        .lang-name {
            font-family: var(--serif);
            font-size: 1.2rem;
            color: var(--text);
            margin-bottom: 0.3rem;
        }
        .lang-level {
            font-family: var(--mono);
            font-size: 10px;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--primary);
            margin-bottom: 0.75rem;
        }
        .lang-bar-bg {
            height: 4px;
            background: var(--border);
            border-radius: 2px;
            overflow: hidden;
        }
        .lang-bar {
            height: 100%;
            background: linear-gradient(to right, var(--primary), #5aabcc);
            border-radius: 2px;
            width: 0;
            transition: width 1s cubic-bezier(0.4,0,0.2,1);
        }

        /* ── Contacto ── */
        .contact-card {
            background: linear-gradient(135deg, #ffffff 0%, #eef5f8 100%);
            border: 1px solid #d4e4ec;
            border-left: 4px solid var(--primary);
            border-radius: 0 14px 14px 0;
            padding: 2rem 2.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 2rem;
            flex-wrap: wrap;
        }
        .contact-card p {
            font-size: 1rem;
            color: var(--text-2);
            margin: 0;
            max-width: 480px;
            line-height: 1.6;
        }
        .contact-links {
            display: flex;
            gap: 0.75rem;
            flex-shrink: 0;
            flex-wrap: wrap;
        }

        @media (max-width: 600px) {
            .layout-wrapper { padding: 2.5rem 1.25rem 5rem; }
            .philosophy-card { padding: 1.75rem 1.5rem; }
            .contact-card { flex-direction: column; align-items: flex-start; }
        }

    </style>
</head>
<body>
    <canvas class="page-canvas" id="page-canvas"></canvas>
    <Header />

    <main class="layout-wrapper">

        <a href="/" class="back-link">← Inicio</a>

        <header class="page-header">
            <span class="eyebrow">Perfil</span>
            <h1><em>Álvaro Fernández Ramos</em></h1>
            <p class="lead">
                Ingeniero informático, investigador de seguridad y constructor de herramientas.
                Último año en la Universidad de Sevilla, con paso por Alemania.
            </p>
        </header>

        <!-- Filosofía -->
        <div class="section">
            <div class="section-label">Filosofía</div>
            <div class="philosophy-card">
                <p>
                    Mi pasión siempre ha estado ligada a una pregunta: <em>¿cómo funciona esto por dentro?</em>
                    Esa curiosidad me llevó a la seguridad — el único campo donde entender los fallos
                    es tan importante como construir lo correcto.
                </p>
                <p>
                    Creo en <strong>romper para defender</strong>. No como un eslogan, sino como metodología real:
                    desarrollar mis propias herramientas (EDRs, gestores de contraseñas, toolkits ofensivos)
                    me da una comprensión que ningún tutorial puede aportar.
                    Cada proyecto es un experimento en el que el objetivo es entender más profundo.
                </p>
            </div>
        </div>

        <!-- Habilidades -->
        <div class="section">
            <div class="section-label">Áreas técnicas</div>
            <div class="skills-grid">
                <div class="skill-card">
                    <div class="skill-title">Ofensiva</div>
                    <div class="skill-tags">
                        <span class="skill-tag">Pentesting</span>
                        <span class="skill-tag">Evasión EDR</span>
                        <span class="skill-tag">Reconocimiento</span>
                        <span class="skill-tag">Payloads</span>
                    </div>
                </div>
                <div class="skill-card">
                    <div class="skill-title">Defensiva</div>
                    <div class="skill-tags">
                        <span class="skill-tag">EDR</span>
                        <span class="skill-tag">Zero-Trust</span>
                        <span class="skill-tag">YARA</span>
                        <span class="skill-tag">Análisis forense</span>
                    </div>
                </div>
                <div class="skill-card">
                    <div class="skill-title">Desarrollo</div>
                    <div class="skill-tags">
                        <span class="skill-tag">Python</span>
                        <span class="skill-tag">Go</span>
                        <span class="skill-tag">FastAPI</span>
                        <span class="skill-tag">Docker</span>
                    </div>
                </div>
                <div class="skill-card">
                    <div class="skill-title">Criptografía</div>
                    <div class="skill-tags">
                        <span class="skill-tag">AES-256-GCM</span>
                        <span class="skill-tag">Argon2id</span>
                        <span class="skill-tag">E2EE</span>
                        <span class="skill-tag">SBOM</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Timeline -->
        <div class="section">
            <div class="section-label">Trayectoria</div>
            <div class="timeline">

                <div class="timeline-item">
                    <span class="time-date">Actualidad</span>
                    <h3>Trabajo de Fin de Grado</h3>
                    <p>Análisis de seguridad del ecosistema de dependencias de Go dentro de la plataforma SecureChain. Resolución formal con Z3, generación de SBOMs y microservicios con FastAPI y Dagster.</p>
                </div>

                <div class="timeline-item">
                    <span class="time-date">Sep 2024 – Jun 2025</span>
                    <h3>Erasmus+ — Emden, Alemania</h3>
                    <p>Estancia académica en Alemania que reforzó mi dominio del inglés técnico, mi adaptabilidad y una visión global del desarrollo de software. Experiencia clave para trabajar en entornos internacionales.</p>
                </div>

                <div class="timeline-item">
                    <span class="time-date">2022 – 2026</span>
                    <h3>Universidad de Sevilla — ETSII</h3>
                    <p>Grado en Ingeniería Informática, especialidad en Tecnologías Informáticas. Bases sólidas en programación de sistemas, análisis de algoritmos e ingeniería de software segura.</p>
                </div>

                <div class="timeline-item">
                    <span class="time-date">2019 – 2021</span>
                    <h3>I.E.S. Profesor Juan Antonio Carrillo Salcedo</h3>
                    <p>Bachillerato de ciencias y tecnología en Morón de la Frontera. Fundamentos lógicos y matemáticos para afrontar la ingeniería informática.</p>
                </div>

            </div>
        </div>

        <!-- Idiomas -->
        <div class="section">
            <div class="section-label">Idiomas</div>
            <div class="lang-grid">
                <div class="lang-card">
                    <div class="lang-name">Español</div>
                    <div class="lang-level">Nativo</div>
                    <div class="lang-bar-bg"><div class="lang-bar" data-width="100"></div></div>
                </div>
                <div class="lang-card">
                    <div class="lang-name">Inglés</div>
                    <div class="lang-level">Profesional (Erasmus)</div>
                    <div class="lang-bar-bg"><div class="lang-bar" data-width="80"></div></div>
                </div>
                <div class="lang-card">
                    <div class="lang-name">Alemán</div>
                    <div class="lang-level">Básico</div>
                    <div class="lang-bar-bg"><div class="lang-bar" data-width="25"></div></div>
                </div>
            </div>
        </div>

        <!-- Contacto -->
        <div class="section">
            <div class="section-label">Contacto</div>
            <div class="contact-card">
                <p>
                    ¿Tienes un proyecto interesante, una oferta o simplemente quieres hablar de seguridad?
                    Puedes encontrarme en LinkedIn o ver mi trabajo en GitHub.
                </p>
                <div class="contact-links">
                    <a href="https://www.linkedin.com/in/álvaro-fernández-71b25a404" target="_blank" class="btn btn-primary">LinkedIn →</a>
                    <a href="https://github.com/alvarofdezr" target="_blank" class="btn btn-ghost">GitHub →</a>
                </div>
            </div>
        </div>

    </main>

    <Footer />

    <script>
    (() => {
        // ── Partículas ──
        const canvas = document.getElementById('page-canvas') as HTMLCanvasElement | null;
        if (canvas) {
            const ctx = canvas.getContext('2d')!;
            let W: number = 0;
            let H: number = 0;
            let particles: Particle[] = [];
            const mouse = { x: -999, y: -999 };
            const isMobile = (): boolean => window.innerWidth < 768;

            function resize(): void {
                W = canvas!.width  = window.innerWidth;
                H = canvas!.height = window.innerHeight;
            }
            resize();
            window.addEventListener('resize', () => { resize(); init(); });
            window.addEventListener('mousemove', (e: MouseEvent) => { mouse.x = e.clientX; mouse.y = e.clientY; });
            window.addEventListener('mouseleave', () => { mouse.x = -999; mouse.y = -999; });

            class Particle {
                x: number = 0; y: number = 0;
                vx: number = 0; vy: number = 0;
                r: number = 0; base: number = 0; alpha: number = 0;

                constructor() { this.reset(); }
                
                reset(): void {
                    this.x     = Math.random() * W;
                    this.y     = Math.random() * H;
                    this.vx    = (Math.random() - 0.5) * 0.3;
                    this.vy    = (Math.random() - 0.5) * 0.3;
                    this.r     = Math.random() * 2.2 + 1.2;
                    const mob  = isMobile();
                    this.base  = mob ? Math.random() * 0.45 + 0.35 : Math.random() * 0.35 + 0.25;
                    this.alpha = this.base;
                }
                update(): void {
                    this.x += this.vx;
                    this.y += this.vy;
                    if (this.x < 0 || this.x > W) this.vx *= -1;
                    if (this.y < 0 || this.y > H) this.vy *= -1;
                    const dx = mouse.x - this.x, dy = mouse.y - this.y;
                    const dist = Math.sqrt(dx*dx + dy*dy);
                    const target = dist < 130 ? this.base + (1 - dist/130) * 0.6 : this.base;
                    this.alpha += (target - this.alpha) * 0.06;
                }
                draw(): void {
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, this.r, 0, Math.PI*2);
                    ctx.fillStyle = `rgba(30,106,138,${this.alpha})`;
                    ctx.fill();
                }
            }

            function init(): void {
                const density = isMobile() ? 6000 : 10000;
                particles = Array.from({ length: Math.floor((W * H) / density) }, () => new Particle());
            }
            init();

            function connect(): void {
                const maxDist = isMobile() ? 100 : 130;
                const baseOp  = isMobile() ? 0.22 : 0.18;
                for (let i = 0; i < particles.length; i++) {
                    for (let j = i+1; j < particles.length; j++) {
                        const a = particles[i], b = particles[j];
                        const dx = a.x-b.x, dy = a.y-b.y;
                        const d  = Math.sqrt(dx*dx + dy*dy);
                        if (d < maxDist) {
                            ctx.beginPath();
                            ctx.moveTo(a.x, a.y);
                            ctx.lineTo(b.x, b.y);
                            ctx.strokeStyle = `rgba(30,106,138,${(1-d/maxDist)*baseOp})`;
                            ctx.lineWidth = 1.0;
                            ctx.stroke();
                        }
                    }
                }
            }

            function loop(): void {
                ctx.clearRect(0, 0, W, H);
                connect();
                particles.forEach(p => { p.update(); p.draw(); });
                requestAnimationFrame(loop);
            }
            loop();
        }

        // ── Timeline scroll reveal ──
        const timelineItems = document.querySelectorAll('.timeline-item');
        const tlObserver = new IntersectionObserver(entries => {
            entries.forEach((entry, i) => {
                if (entry.isIntersecting) {
                    setTimeout(() => entry.target.classList.add('visible'), i * 120);
                    tlObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.15 });
        timelineItems.forEach(el => tlObserver.observe(el));

        // ── Barras de idiomas animadas ──
        const bars = document.querySelectorAll('.lang-bar');
        const barObserver = new IntersectionObserver(entries => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const bar = entry.target as HTMLElement; // Casteo necesario para acceder a dataset
                    bar.style.width = bar.dataset.width + '%';
                    barObserver.unobserve(bar);
                }
            });
        }, { threshold: 0.5 });
        bars.forEach(b => barObserver.observe(b));
    })();
    </script>
</body>
</html>