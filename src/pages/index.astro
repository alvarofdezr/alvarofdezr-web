---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Álvaro Fernández Ramos";
const description = "Computer Engineering student specializing in secure software development and offensive security research.";
---

<!DOCTYPE html>
<html lang="es">
<head>
    <BaseHead title={title} description={description} />
    <style>
        /* ── Hero wrapper ── */
        .hero-wrapper {
            position: relative;
            overflow: hidden;
            background: var(--bg);
        }

        #hero-canvas {
            position: absolute;
            inset: 0;
            pointer-events: none;
            z-index: 0;
            -webkit-mask-image:
                radial-gradient(ellipse 50% 100% at 15% 50%, black 0%, black 40%, transparent 75%),
                radial-gradient(ellipse 50% 100% at 85% 50%, black 0%, black 40%, transparent 75%);
            -webkit-mask-composite: source-over;
            mask-image:
                radial-gradient(ellipse 50% 100% at 15% 50%, black 0%, black 40%, transparent 75%),
                radial-gradient(ellipse 50% 100% at 85% 50%, black 0%, black 40%, transparent 75%);
            mask-composite: add;
        }

        .layout-wrapper {
            box-sizing: border-box;
            max-width: 1100px;
            margin: 0 auto;
            padding: 4rem 2rem 5rem;
            min-height: calc(100vh - 160px);
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
            z-index: 1;
        }

        .hero-section {
            max-width: 800px;
            margin-bottom: 4.5rem;
        }

        .hero-tag {
            font-family: var(--mono);
            font-size: 11px;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: var(--primary);
            margin-bottom: 1.4rem;
            display: block;
            opacity: 0;
            animation: fadeUp 0.6s ease 0.2s forwards;
        }

        .hero-section h1 {
            font-family: var(--serif);
            font-size: clamp(2.6rem, 6vw, 4.2rem);
            margin: 0 0 1rem;
            color: var(--text);
            font-weight: 400;
            letter-spacing: -0.02em;
            line-height: 1.05;
            opacity: 0;
            animation: fadeUp 0.7s ease 0.4s forwards;
        }

        .hero-section h1 em { font-style: italic; color: var(--primary); }

        .hero-section .subtitle {
            font-family: var(--mono);
            font-size: 12px;
            color: var(--text-3);
            margin-bottom: 2rem;
            font-weight: 300;
            letter-spacing: 0.06em;
            opacity: 0;
            animation: fadeUp 0.7s ease 0.6s forwards;
        }

        .hero-section .bio {
            font-size: 1.05rem;
            color: var(--text-2);
            max-width: 540px;
            margin-bottom: 0;
            border-left: 2px solid var(--primary-border);
            padding-left: 1.4rem;
            line-height: 1.75;
            opacity: 0;
            animation: fadeUp 0.7s ease 0.8s forwards;
        }
        .hero-section .bio strong { color: #1a2830; font-weight: 500; }

        .chips {
            display: flex;
            gap: 0.5rem;
            margin-top: 2rem;
            flex-wrap: wrap;
            opacity: 0;
            animation: fadeUp 0.7s ease 1s forwards;
        }
        .chip {
            font-family: var(--mono);
            font-size: 10px;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            padding: 5px 11px;
            border: 1px solid var(--primary-border);
            border-radius: 2px;
            color: var(--primary);
            background: var(--primary-light);
        }

        .nav-section {
            opacity: 0;
            animation: fadeUp 0.7s ease 1.1s forwards;
        }
        .nav-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.25rem;
        }
        .nav-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 2rem 1.75rem;
            text-decoration: none;
            color: inherit;
            transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
        .nav-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0;
            width: 4px; height: 100%;
            background: var(--primary);
            transform: scaleY(0);
            transform-origin: bottom;
            transition: transform 0.3s ease;
        }
        .nav-card:hover { transform: translateY(-4px); box-shadow: 0 16px 32px -8px rgba(0,0,0,0.08); border-color: transparent; }
        .nav-card:hover::before { transform: scaleY(1); }

        .card-header { display: flex; align-items: center; justify-content: space-between; }
        .nav-card h2 { margin: 0; font-size: 1.15rem; color: var(--text); font-weight: 600; letter-spacing: -0.01em; }
        .arrow { color: var(--text-3); font-size: 1.1rem; font-weight: 300; transition: transform 0.3s ease, color 0.3s ease; flex-shrink: 0; }
        .nav-card:hover .arrow { transform: translateX(4px); color: var(--primary); }
        .nav-card p { margin: 0; color: var(--text-2); font-size: 0.9rem; line-height: 1.6; }

        @media (max-width: 768px) {
            .layout-wrapper { padding: 3rem 1.25rem 4rem; min-height: auto; }
            .hero-section { margin-bottom: 3rem; }
            .hero-section h1 { font-size: 2.4rem; }
            .nav-grid { grid-template-columns: 1fr; gap: 1rem; }
            .nav-card { padding: 1.4rem 1.25rem; }
        }
    </style>
</head>
<body>
    <Header />

    <div class="hero-wrapper" id="hero-wrapper">
        <canvas id="hero-canvas"></canvas>
        <main class="layout-wrapper">
            <section class="hero-section">
                <span class="hero-tag">Security Engineer · Sevilla</span>
                <h1><em>Álvaro</em><br>Fernández Ramos</h1>
                <p class="subtitle">Ingeniería Informática · Tecnologías Informáticas</p>
                <p class="bio">
                    Construyo <strong>software seguro</strong> y rompo sistemas para entender cómo defenderlos.
                    Investigación en <strong>seguridad ofensiva</strong>, análisis de malware
                    y arquitecturas Zero-Trust.
                </p>
                <div class="chips" aria-hidden="true">
                    <span class="chip">EDR</span>
                    <span class="chip">Offensive Sec</span>
                    <span class="chip">Malware Analysis</span>
                    <span class="chip">Zero-Trust</span>
                </div>
            </section>

            <nav class="nav-section" aria-label="Secciones principales">
                <div class="nav-grid">
                    <a href="/proyectos" class="nav-card">
                        <div class="card-header">
                            <h2>Proyectos destacados</h2>
                            <span class="arrow" aria-hidden="true">→</span>
                        </div>
                        <p>Harpocrates, Basilisk, Ares y otros desarrollos en seguridad local, EDR y ofensiva.</p>
                    </a>
                    <a href="/stack" class="nav-card">
                        <div class="card-header">
                            <h2>Stack y certificaciones</h2>
                            <span class="arrow" aria-hidden="true">→</span>
                        </div>
                        <p>Arsenal tecnológico, entornos de desarrollo y progreso en eJPT y OSCP.</p>
                    </a>
                    <a href="/perfil" class="nav-card">
                        <div class="card-header">
                            <h2>Sobre mí</h2>
                            <span class="arrow" aria-hidden="true">→</span>
                        </div>
                        <p>Trayectoria, filosofía de seguridad y objetivos dentro de la industria.</p>
                    </a>
                </div>
            </nav>
        </main>
    </div>

    <Footer />

    <script>
    (() => {
        const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
        const wrap   = document.getElementById('hero-wrapper') as HTMLElement | null;
        if (!canvas || !wrap) return;

        const ctx = canvas.getContext('2d')!;
        let W: number = 0;
        let H: number = 0;
        let particles: Particle[] = [];
        const mouse = { x: -999, y: -999 };
        const isMobile = (): boolean => window.innerWidth < 768;

        function resize(): void {
            W = canvas!.width  = wrap!.offsetWidth;
            H = canvas!.height = wrap!.offsetHeight;
        }
        resize();
        window.addEventListener('resize', () => { resize(); init(); });
        wrap.addEventListener('mousemove', (e: MouseEvent) => {
            const r = wrap!.getBoundingClientRect();
            mouse.x = e.clientX - r.left;
            mouse.y = e.clientY - r.top;
        });
        wrap.addEventListener('mouseleave', () => { mouse.x = -999; mouse.y = -999; });
        wrap.addEventListener('touchmove', (e: TouchEvent) => {
            const r = wrap!.getBoundingClientRect();
            const t = e.touches[0];
            mouse.x = t.clientX - r.left;
            mouse.y = t.clientY - r.top;
        }, { passive: true });
        wrap.addEventListener('touchend', () => { mouse.x = -999; mouse.y = -999; });

        class Particle {
            x: number = 0;
            y: number = 0;
            vx: number = 0;
            vy: number = 0;
            r: number = 0;
            base: number = 0;
            alpha: number = 0;

            constructor() { this.reset(); }

            reset(): void {
                this.x    = Math.random() * W;
                this.y    = Math.random() * H;
                this.vx   = (Math.random() - 0.5) * 0.3;
                this.vy   = (Math.random() - 0.5) * 0.3;
                this.r    = Math.random() * 2.2 + 1.2;
                this.base = isMobile() ? Math.random() * 0.45 + 0.35 : Math.random() * 0.35 + 0.25;
                this.alpha = this.base;
            }

            update(): void {
                this.x += this.vx;
                this.y += this.vy;
                if (this.x < 0 || this.x > W) this.vx *= -1;
                if (this.y < 0 || this.y > H) this.vy *= -1;
                const dx   = mouse.x - this.x;
                const dy   = mouse.y - this.y;
                const dist = Math.sqrt(dx * dx + dy * dy);
                const target = dist < 130 ? this.base + (1 - dist / 130) * 0.6 : this.base;
                this.alpha += (target - this.alpha) * 0.06;
            }

            draw(): void {
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(30,106,138,${this.alpha})`;
                ctx.fill();
            }
        }

        function init(): void {
            particles = Array.from(
                { length: Math.floor((W * H) / (isMobile() ? 6000 : 10000)) },
                () => new Particle()
            );
        }
        init();

        function connect(): void {
            const maxDist = isMobile() ? 100 : 130;
            const baseOp  = isMobile() ? 0.22 : 0.18;
            for (let i = 0; i < particles.length; i++) {
                for (let j = i + 1; j < particles.length; j++) {
                    const a = particles[i], b = particles[j];
                    const dx = a.x - b.x, dy = a.y - b.y;
                    const d  = Math.sqrt(dx * dx + dy * dy);
                    if (d < maxDist) {
                        ctx.beginPath();
                        ctx.moveTo(a.x, a.y);
                        ctx.lineTo(b.x, b.y);
                        ctx.strokeStyle = `rgba(30,106,138,${(1 - d / maxDist) * baseOp})`;
                        ctx.lineWidth = 1;
                        ctx.stroke();
                    }
                }
            }
        }

        function loop(): void {
            ctx.clearRect(0, 0, W, H);
            connect();
            particles.forEach(p => { p.update(); p.draw(); });
            requestAnimationFrame(loop);
        }
        loop();
    })();
    </script>
</body>
</html>