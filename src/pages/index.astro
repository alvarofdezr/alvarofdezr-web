---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Álvaro Fernández Ramos";
const description = "Computer Engineering student specializing in secure software development and offensive security research.";
---

<!DOCTYPE html>
<html lang="es">
<head>
    <BaseHead title={title} description={description} />
    <style>
        :root {
            --primary: #0e75b6; 
            --primary-dark: #0b5b8e;
            --bg-color: #fafbfc;
            --text-main: #24292e;
            --text-muted: #586069;
            --card-bg: #ffffff;
            --border-color: #e1e4e8;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        .layout-wrapper {
            width: auto;
            box-sizing: border-box;
            max-width: 1100px;
            margin: 0 auto;
            padding: 4rem 2rem;
            min-height: calc(100vh - 160px);
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .hero-section {
            max-width: 800px;
            margin-bottom: 5rem;
        }

        .greeting {
            color: var(--primary);
            font-weight: 600;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            font-size: 0.9rem;
            margin-bottom: 1rem;
            display: block;
        }

        .hero-section h1 {
            font-size: 4rem;
            margin: 0 0 1rem 0;
            color: #111827;
            font-weight: 800;
            letter-spacing: -0.04em;
            line-height: 1.1;
        }

        .hero-section .subtitle {
            font-size: 1.5rem;
            color: var(--text-muted);
            margin-bottom: 2rem;
            font-weight: 400;
            max-width: 600px;
            line-height: 1.4;
        }

        .hero-section .bio {
            font-size: 1.125rem;
            color: #4b5563;
            max-width: 650px;
            margin-bottom: 3rem;
            border-left: 3px solid var(--primary);
            padding-left: 1.5rem;
        }

        .nav-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); 
            gap: 2rem;
            width: 100%;
        }

        .nav-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 2.5rem 2rem;
            text-decoration: none;
            color: inherit;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .nav-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: var(--primary);
            transform: scaleY(0);
            transform-origin: bottom;
            transition: transform 0.3s ease;
        }

        .nav-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
            border-color: transparent;
        }

        .nav-card:hover::before {
            transform: scaleY(1);
        }

        .nav-card h2 {
            margin: 0 0 0.75rem 0;
            font-size: 1.5rem;
            color: #111827;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .arrow {
            color: var(--text-muted);
            font-weight: 300;
            transition: transform 0.3s ease, color 0.3s ease;
        }

        .nav-card:hover .arrow {
            transform: translateX(5px);
            color: var(--primary);
        }

        .nav-card p {
            margin: 0;
            color: var(--text-muted);
            font-size: 1rem;
            line-height: 1.5;
        }

        @media (max-width: 768px) {
            .hero-section h1 {
                font-size: 2.5rem;
            }
            .hero-section .subtitle {
                font-size: 1.2rem;
            }
            .layout-wrapper {
                padding: 2rem 1.5rem;
            }
            .nav-card {
                padding: 1.5rem;
            }
        }
        @media (prefers-reduced-motion: reduce) {
            * {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
                scroll-behavior: auto !important;
                opacity: 1 !important; 
            }
        }
    </style>
</head>
<body>
    <Header />
    
    <main class="layout-wrapper">
        <section class="hero-section">
            <h1>Álvaro Fernández Ramos</h1>
            <p class="subtitle">Ingeniería Informática. Tecnologías Informáticas</p>
            
            <p class="bio">
                Construyo software seguro y rompo sistemas para entender cómo defenderlos. 
                Investigación en seguridad ofensiva, análisis de malware y desarrollo de arquitecturas Zero-Trust.
            </p>
        </section>

        <nav class="nav-grid">
            <a href="/projects" class="nav-card">
                <h2>Proyectos destacados <span class="arrow">→</span></h2>
                <p>Explora Harpocrates, Basilisk, Ares y otros desarrollos centrados en seguridad local, EDR y herramientas ofensivas.</p>
            </a>

            <a href="/stack" class="nav-card">
                <h2>Stack y certificaciones <span class="arrow">→</span></h2>
                <p>Descubre mi arsenal tecnológico, entornos de desarrollo y el progreso de mis certificaciones eJPT y OSCP.</p>
            </a>

            <a href="/profile" class="nav-card">
                <h2>Sobre mi <span class="arrow">→</span></h2>
                <p>Conoce mi trayectoria académica, filosofía de seguridad y objetivos profesionales dentro de la industria.</p>
            </a>
        </nav>
    </main>
    
    <Footer />
</body>
</html>